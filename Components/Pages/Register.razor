@page "/register"
@using RestaurantOrderingSystem.Services
@using RestaurantOrderingSystem.Models
@inject AuthService AuthService
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="login-page-wrapper">
    <div class="login-card">
        <div class="login-header">
            <h2><span>Create</span> Account</h2>
            <p>Join the zone for faster ordering!</p>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">
                <i class="bi bi-exclamation-triangle"></i> @errorMessage
            </div>
        }

        <div class="form-container">
            <div class="form-group">
                <label><i class="bi bi-person"></i> Name</label>
                <input type="text" @bind="userModel.Name" placeholder="John Doe" />
            </div>

            <div class="form-group">
                <label><i class="bi bi-envelope"></i> Email Address</label>
                <input type="email" @bind="userModel.Email" placeholder="your@email.com" />
            </div>

            <div class="form-group">
                <label><i class="bi bi-lock"></i> Password</label>
                <input type="password" @bind="userModel.Password" placeholder="Minimum 6 characters" />
            </div>

            <div class="form-group">
                <label><i class="bi bi-shield-check"></i> Confirm Password</label>
                <input type="password" @bind="confirmPassword" placeholder="Repeat password" />
            </div>

            <button class="btn-submit" @onclick="HandleRegister" disabled="@isProcessing">
                @if (isProcessing)
                {
                    <span class="spinner-border spinner-border-sm"></span> <span>CREATING ZONE...</span>
                }
                else
                {
                    <span>JOIN BITEZONE</span>
                }
            </button>
        </div>

        <div class="login-footer">
            <p>Already have an account? <span class="highlight" @onclick='() => Nav.NavigateTo("/login")'>Log In</span>
            </p>
        </div>
    </div>
</div>

@code {
    private User userModel = new();
    private string confirmPassword = "";
    private string? errorMessage;
    private bool isProcessing = false;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthStateTask { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (AuthStateTask != null)
        {
            var authState = await AuthStateTask;
            if (authState.User.Identity?.IsAuthenticated ?? false)
            {
                Nav.NavigateTo("/menu");
            }
        }
    }

    private async Task HandleRegister()
    {
        if (isProcessing) return;
        errorMessage = null;

        // Simple Validation
        if (string.IsNullOrWhiteSpace(userModel.Name) || string.IsNullOrWhiteSpace(userModel.Email))
        {
            errorMessage = "All fields are required.";
            return;
        }

        if (userModel.Password.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        if (userModel.Password != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        try
        {
            isProcessing = true;
            userModel.Role = "customer"; // Ensure they aren't registering as Admin

            var success = await AuthService.RegisterAsync(userModel);

            if (success)
            {
                // Auto-login or redirect to login
                Nav.NavigateTo("/login");
            }
            else
            {
                errorMessage = "This email is already registered.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Database connection failed.";
            Console.WriteLine(ex.Message);
        }
        finally
        {
            isProcessing = false;
        }
    }
}

<style>
    /* Reuse the CSS from your Login.razor file here */
    /* Add this specific class for the error alert */
    :root {
        --bz-purple: #3c3f6a;
        --bz-purple-dark: #2d2f50;
        --bz-yellow: #ffcc33;
        --bz-red: #ff4747;
        --bz-red-dark: #b33030;
    }

    .login-page-wrapper {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 170px);
        padding: 2rem;
    }

    .login-card {
        background: white;
        padding: 3rem 2.5rem;
        border-radius: 20px;
        box-shadow: 0 15px 35px rgba(60, 63, 106, 0.15);
        width: 100%;
        max-width: 450px;
        border-top: 5px solid var(--bz-yellow);
    }

    /* Header & Logo */
    .login-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .login-header h2 {
        font-weight: 900;
        color: var(--bz-purple);
        letter-spacing: -1px;
        margin: 0;
        text-transform: uppercase;
    }

    .login-header h2 span {
        color: var(--bz-yellow);
    }

    .login-header p {
        color: #666;
        font-size: 0.9rem;
        margin-top: 0.5rem;
    }

    /* Form Fields */
    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 0.6rem;
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--bz-purple);
        text-transform: uppercase;
    }

    .form-group input {
        width: 100%;
        padding: 0.9rem 1.2rem;
        border: 2px solid #eee;
        border-radius: 12px;
        font-size: 1rem;
        transition: all 0.3s ease;
        background: #fdfdfd;
    }

    .form-group input:focus {
        outline: none;
        border-color: var(--bz-purple);
        background: white;
        box-shadow: 0 0 0 4px rgba(60, 63, 106, 0.1);
    }

    /* Buttons */
    .btn-submit {
        width: 100%;
        padding: 1rem;
        background-color: var(--bz-red);
        color: white;
        border: none;
        border-radius: 12px;
        font-size: 1.1rem;
        font-weight: 800;
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        box-shadow: 0 5px 0 var(--bz-red-dark);
        margin-top: 0.5rem;
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 0 var(--bz-red-dark);
        background-color: #ff5e5e;
    }

    .btn-submit:active {
        transform: translateY(3px);
        box-shadow: 0 0px 0 var(--bz-red-dark);
    }

    .alert-error {
        background-color: #ffe5e5;
        color: #d32f2f;
        padding: 0.8rem;
        border-radius: 12px;
        margin-bottom: 1.5rem;
        font-size: 0.85rem;
        font-weight: 600;
        display: flex;
        align-items: center;
        gap: 10px;
        border: 1px solid #ffcccc;
    }

    /* Footer */
    .login-footer {
        margin-top: 2rem;
        text-align: center;
        font-size: 0.9rem;
        color: #666;
    }
</style>