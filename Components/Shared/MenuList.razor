@using RestaurantOrderingSystem.Models
@using RestaurantOrderingSystem.Services
@inject MenuListService MenuListSvc

<div>

    <h1>Testing</h1>

    @if (products == null)
    {
        <p>Loading...</p>
    } 
    else
    {
        <div class="row">
            @foreach (var p in products)
            {   
                // Grid Div
                <div class="col-12 col-sm-6 col-md-4 col-lg-3 mb-4">

                    @* Cards to Display Products(Itemns) on Menu List *@
                    <div class="card h-100 shadow hover-scale" data-bs-toggle="modal" data-bs-target="#productModal">

                        <div class="ratio ratio-1x1">
                            <img src="@p.ImageUrl" class="card-img-top object-fit-cover" alt="@p.Name" loading="lazy">
                        </div>

                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-center">@p.Name</h5>


                        </div>

                    </div>
                    
                </div>
            }
        </div>

        <ProductModal />
    }

</div>

<style>

    .hover-scale{
        transition: all 0.3s ease;
    }

    .hover-scale:hover{
        transform: scale(1.05) translateY(-5px);
    }

</style>



@code{

    private List<Product> products = new();

    protected override async Task OnInitializedAsync()
    {
        products = await MenuListSvc.GetProductsAsync();
    }
}
